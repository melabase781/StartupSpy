<Window x:Class="StartupSpy.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:StartupSpy.ViewModels"
    xmlns:conv="clr-namespace:StartupSpy.Converters"
    Title="StartupSpy" Height="780" Width="1280"
    MinHeight="600" MinWidth="900"
    WindowStartupLocation="CenterScreen"
    Background="#0A0D14"
    FontFamily="Segoe UI"
    Icon="pack://application:,,,/app.ico">


    <Window.Resources>
        <conv:RiskToColorConverter x:Key="RiskToColor" />
        <conv:RiskToBgConverter x:Key="RiskToBg" />
        <conv:CategoryToIconConverter x:Key="CatToIcon" />
        <conv:BoolToEnabledTextConverter x:Key="BoolToEnabled" />
        <conv:BoolToEnabledColorConverter x:Key="BoolToEnabledColor" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <conv:ZeroToVisibilityConverter x:Key="ZeroToVis" />

        <!-- List item style -->
        <Style x:Key="EntryListItem" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Root" Background="Transparent"
                            CornerRadius="8" Padding="0"
                            BorderThickness="1" BorderBrush="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#111827" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1E2D45" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0F1E35" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3B82F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Category filter button -->
        <Style x:Key="FilterBtn" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2535" />
                                <Setter Property="Foreground" Value="#CBD5E1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scan button -->
        <Style x:Key="ScanBtn" TargetType="Button">
            <Setter Property="Background" Value="#1D4ED8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="24,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E40AF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2535" />
                                <Setter Property="Foreground" Value="#475569" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon action button -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#111827" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#1E2535" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2535" />
                                <Setter Property="Foreground" Value="#CBD5E1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#334155" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Header -->
            <RowDefinition Height="Auto" />
            <!-- Stats bar -->
            <RowDefinition Height="Auto" />
            <!-- Filter bar -->
            <RowDefinition Height="*" />
            <!-- Main content -->
            <RowDefinition Height="Auto" />
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#060911" Padding="28,20,28,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Logo -->
                    <Border Width="38" Height="38" CornerRadius="10"
                        Margin="0,0,14,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1D4ED8" Offset="0" />
                                <GradientStop Color="#7C3AED" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Image Source="pack://application:,,,/app.ico" Width="24" Height="24"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="StartupSpy" FontSize="20" FontWeight="Bold"
                            Foreground="White"
                        />
                        <TextBlock Text="Windows Startup Manager" FontSize="11" Foreground="#475569"
                            Margin="0,1,0,0" />
                    </StackPanel>
                </StackPanel>

                <!-- Search + Scan -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#0F1629" CornerRadius="8"
                        BorderThickness="1" BorderBrush="#1E2D45"
                        Padding="12,0" Width="280" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center"
                                Margin="0,0,8,0" Opacity="0.5" />
                            <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0"
                                Foreground="#CBD5E1" CaretBrush="#3B82F6"
                                FontSize="13" Height="36" VerticalContentAlignment="Center"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                Tag="Search by name, publisher, path...">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <Grid>
                                                                <TextBlock
                                                                    Text="{TemplateBinding Tag}"
                                                                    Foreground="#334155"
                                                                    VerticalAlignment="Center"
                                                                    IsHitTestVisible="False"
                                                                    FontSize="13" />
                                                                <ScrollViewer
                                                                    x:Name="PART_ContentHost"
                                                                    VerticalAlignment="Center" />
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>

                    <Button Style="{StaticResource ScanBtn}"
                        Command="{Binding ScanCommand}"
                        IsEnabled="{Binding IsNotScanning}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟳" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock Text="Scan System" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ STATS BAR ═══ -->
        <Border Grid.Row="1" Background="#080C17" Padding="28,14">
            <StackPanel Orientation="Horizontal">
                <!-- Stat cards -->
                <Border Background="#0D1526" CornerRadius="8" Padding="16,10" Margin="0,0,10,0"
                    BorderThickness="1" BorderBrush="#1A2540" MinWidth="130">
                    <StackPanel>
                        <TextBlock Text="TOTAL ENTRIES" FontSize="9" Foreground="#475569"
                            FontWeight="Bold" />
                        <TextBlock Text="{Binding TotalCount}" FontSize="26" FontWeight="Bold"
                            Foreground="#E2E8F0" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="#0D1526" CornerRadius="8" Padding="16,10" Margin="0,0,10,0"
                    BorderThickness="1" BorderBrush="#1A2540" MinWidth="130">
                    <StackPanel>
                        <TextBlock Text="HIGH RISK" FontSize="9" Foreground="#475569"
                            FontWeight="Bold" />
                        <TextBlock Text="{Binding HighRiskCount}" FontSize="26" FontWeight="Bold"
                            Foreground="#EF4444" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="#0D1526" CornerRadius="8" Padding="16,10" Margin="0,0,10,0"
                    BorderThickness="1" BorderBrush="#1A2540" MinWidth="130">
                    <StackPanel>
                        <TextBlock Text="UNKNOWN" FontSize="9" Foreground="#475569"
                            FontWeight="Bold" />
                        <TextBlock Text="{Binding UnknownCount}" FontSize="26" FontWeight="Bold"
                            Foreground="#94A3B8" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="#0D1526" CornerRadius="8" Padding="16,10" Margin="0,0,10,0"
                    BorderThickness="1" BorderBrush="#1A2540" MinWidth="130">
                    <StackPanel>
                        <TextBlock Text="SAFE" FontSize="9" Foreground="#475569" FontWeight="Bold" />
                        <TextBlock Text="{Binding SafeCount}" FontSize="26" FontWeight="Bold"
                            Foreground="#22C55E" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <!-- Quick filter -->
                <Border Background="#2D0A0A" CornerRadius="8" Padding="14,10" Margin="16,0,0,0"
                    BorderThickness="1" BorderBrush="#4B1010" Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                            Command="{Binding FilterHighRiskCommand}" />
                    </Border.InputBindings>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚠" FontSize="14" Foreground="#EF4444" Margin="0,0,8,0" />
                        <TextBlock Text="Show High Risk" FontSize="12" Foreground="#FCA5A5"
                            FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <!-- Scanning spinner -->
                <Border Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"
                    Margin="20,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="16" Height="16" Margin="0,0,8,0">
                            <Border.RenderTransform>
                                <RotateTransform x:Name="SpinTransform" CenterX="8" CenterY="8" />
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="SpinTransform"
                                                Storyboard.TargetProperty="Angle"
                                                From="0" To="360" Duration="0:0:1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Ellipse Width="16" Height="16" StrokeThickness="2">
                                <Ellipse.Stroke>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3B82F6" Offset="0" />
                                        <GradientStop Color="Transparent" Offset="1" />
                                    </LinearGradientBrush>
                                </Ellipse.Stroke>
                            </Ellipse>
                        </Border>
                        <TextBlock Text="Scanning..." FontSize="12" Foreground="#3B82F6"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══ FILTER BAR ═══ -->
        <Border Grid.Row="2" Background="#060911" Padding="24,10" BorderThickness="0,1,0,1"
            BorderBrush="#0F1629">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="FILTER" FontSize="10" Foreground="#334155" FontWeight="Bold"
                    VerticalAlignment="Center" Margin="0,0,14,0" />
                <RadioButton Style="{StaticResource FilterBtn}" Content="All" GroupName="Cat"
                    IsChecked="True"
                    Command="{Binding DataContext.ScanCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Checked="CategoryFilter_Checked" Tag="All" />
                <RadioButton Style="{StaticResource FilterBtn}" Content="⚙ Registry" GroupName="Cat"
                    Checked="CategoryFilter_Checked" Tag="Registry" Margin="4,0,0,0" />
                <RadioButton Style="{StaticResource FilterBtn}" Content="📁 Startup Folder"
                    GroupName="Cat"
                    Checked="CategoryFilter_Checked" Tag="Startup Folder" Margin="4,0,0,0" />
                <RadioButton Style="{StaticResource FilterBtn}" Content="🕐 Scheduled Tasks"
                    GroupName="Cat"
                    Checked="CategoryFilter_Checked" Tag="Scheduled Task" Margin="4,0,0,0" />
                <RadioButton Style="{StaticResource FilterBtn}" Content="⚡ Services" GroupName="Cat"
                    Checked="CategoryFilter_Checked" Tag="Service" Margin="4,0,0,0" />
            </StackPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- List panel -->
            <Border Grid.Column="0" Background="#080C17" Padding="16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Column headers -->
                    <Grid Grid.Row="0" Margin="12,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="" FontSize="10" Foreground="#334155"
                            FontWeight="Bold" />
                        <TextBlock Grid.Column="1" Text="NAME" FontSize="10" Foreground="#334155"
                            FontWeight="Bold" />
                        <TextBlock Grid.Column="2" Text="PUBLISHER" FontSize="10"
                            Foreground="#334155" FontWeight="Bold" />
                        <TextBlock Grid.Column="3" Text="RISK" FontSize="10" Foreground="#334155"
                            FontWeight="Bold" />
                        <TextBlock Grid.Column="4" Text="STATUS" FontSize="10" Foreground="#334155"
                            FontWeight="Bold" />
                        <TextBlock Grid.Column="5" Text="PATH" FontSize="10" Foreground="#334155"
                            FontWeight="Bold" />
                    </Grid>

                    <ListView Grid.Row="1" ItemsSource="{Binding Entries}"
                        SelectedItem="{Binding SelectedEntry}"
                        Background="Transparent" BorderThickness="0"
                        ItemContainerStyle="{StaticResource EntryListItem}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        VirtualizingPanel.IsVirtualizing="True">

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="12,7" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Category icon -->
                                    <TextBlock Grid.Column="0"
                                        Text="{Binding Category, Converter={StaticResource CatToIcon}}"
                                        FontSize="15" VerticalAlignment="Center" Opacity="0.7" />

                                    <!-- Name -->
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                        FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0"
                                        VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                                    <!-- Publisher -->
                                    <TextBlock Grid.Column="2" Text="{Binding Publisher}"
                                        FontSize="12" Foreground="#64748B"
                                        VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />

                                    <!-- Risk badge -->
                                    <Border Grid.Column="3" CornerRadius="4"
                                        Background="{Binding Risk, Converter={StaticResource RiskToBg}}"
                                        Padding="8,3" HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                        <TextBlock Text="{Binding RiskLabel}" FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{Binding Risk, Converter={StaticResource RiskToColor}}" />
                                    </Border>

                                    <!-- Status dot -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                        <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                            Fill="{Binding IsEnabled, Converter={StaticResource BoolToEnabledColor}}" />
                                        <TextBlock
                                            Text="{Binding IsEnabled, Converter={StaticResource BoolToEnabled}}"
                                            FontSize="11"
                                            Foreground="{Binding IsEnabled, Converter={StaticResource BoolToEnabledColor}}" />
                                    </StackPanel>

                                    <!-- Path -->
                                    <TextBlock Grid.Column="5" Text="{Binding FilePath}"
                                        FontSize="11" Foreground="#334155" FontFamily="Consolas"
                                        VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Empty state -->
                    <Border Grid.Row="1"
                        Visibility="{Binding Entries.Count, Converter={StaticResource ZeroToVis}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center"
                                Opacity="0.2" />
                            <TextBlock Text="No entries found" FontSize="15" Foreground="#1E2535"
                                HorizontalAlignment="Center" Margin="0,12,0,6" />
                            <TextBlock Text="Run a scan to discover startup programs" FontSize="12"
                                Foreground="#1A2540" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Detail panel -->
            <Border Grid.Column="1" Background="#060911" BorderThickness="1,0,0,0"
                BorderBrush="#0F1629">
                <Grid>

                    <!-- No selection -->
                    <Border
                        Visibility="{Binding SelectedEntry, Converter={StaticResource NullToVis}}"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Padding="32">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="→" FontSize="36" Foreground="#1A2540"
                                HorizontalAlignment="Center" />
                            <TextBlock Text="Select an entry" FontSize="14" Foreground="#1E2D45"
                                HorizontalAlignment="Center" Margin="0,10,0,4" />
                            <TextBlock Text="to view details" FontSize="12" Foreground="#161E30"
                                HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Entry detail -->
                    <ScrollViewer
                        Visibility="{Binding SelectedEntry, Converter={StaticResource NullToVis}}"
                        Padding="24">
                        <StackPanel DataContext="{Binding SelectedEntry}">
                            <!-- Risk header -->
                            <Border CornerRadius="10" Padding="16,12" Margin="0,0,0,16"
                                Background="{Binding Risk, Converter={StaticResource RiskToBg}}"
                                BorderThickness="1"
                                BorderBrush="{Binding Risk, Converter={StaticResource RiskToColor}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="RISK LEVEL" FontSize="9" FontWeight="Bold"
                                            Foreground="#475569" />
                                        <TextBlock Text="{Binding RiskLabel}" FontSize="22"
                                            FontWeight="Bold"
                                            Foreground="{Binding Risk, Converter={StaticResource RiskToColor}}"
                                            Margin="0,2,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                        Text="{Binding Category, Converter={StaticResource CatToIcon}}"
                                        FontSize="28" VerticalAlignment="Center" Opacity="0.6" />
                                </Grid>
                            </Border>

                            <!-- Name -->
                            <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="Bold"
                                Foreground="#F1F5F9" TextWrapping="Wrap" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Publisher}" FontSize="12" Foreground="#64748B"
                                Margin="0,0,0,16" />

                            <!-- Divider -->
                            <Border Height="1" Background="#0F1629" Margin="0,0,0,16" />

                            <!-- Detail rows -->
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Category" FontSize="11" Foreground="#475569"
                                        VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="1" Text="{Binding CategoryLabel}"
                                        FontSize="12" Foreground="#CBD5E1" TextWrapping="Wrap" />
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Status" FontSize="11" Foreground="#475569"
                                        VerticalAlignment="Top" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Fill="{Binding IsEnabled, Converter={StaticResource BoolToEnabledColor}}" />
                                        <TextBlock
                                            Text="{Binding IsEnabled, Converter={StaticResource BoolToEnabled}}"
                                            FontSize="12"
                                            Foreground="{Binding IsEnabled, Converter={StaticResource BoolToEnabledColor}}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Location" FontSize="11" Foreground="#475569"
                                        VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="1" Text="{Binding Location}"
                                        FontSize="11"
                                        Foreground="#64748B" FontFamily="Consolas"
                                        TextWrapping="Wrap" />
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Path" FontSize="11" Foreground="#475569"
                                        VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="1" Text="{Binding FilePath}"
                                        FontSize="11"
                                        Foreground="#64748B" FontFamily="Consolas"
                                        TextWrapping="Wrap" />
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Command" FontSize="11" Foreground="#475569"
                                        VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="1" Text="{Binding Command}"
                                        FontSize="11"
                                        Foreground="#64748B" FontFamily="Consolas"
                                        TextWrapping="Wrap" />
                                </Grid>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Delay" FontSize="11" Foreground="#475569"
                                        VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="1" Text="{Binding StartupDelay}"
                                        FontSize="12" Foreground="#CBD5E1" />
                                </Grid>
                            </StackPanel>

                            <!-- Description -->
                            <Border Background="#0D1526" CornerRadius="8" Padding="12"
                                Margin="0,0,0,16"
                                Visibility="{Binding Description, Converter={StaticResource NullToVis}}">
                                <StackPanel>
                                    <TextBlock Text="DESCRIPTION" FontSize="9" Foreground="#334155"
                                        FontWeight="Bold"
                                        Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding Description}" FontSize="12"
                                        Foreground="#64748B" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <!-- Action buttons -->
                            <Border Height="1" Background="#0F1629" Margin="0,0,0,12" />
                            <TextBlock Text="ACTIONS" FontSize="9" Foreground="#334155"
                                FontWeight="Bold"
                                Margin="0,0,0,10" />
                            <!-- Toggle enable/disable button -->
                            <Button Style="{StaticResource ScanBtn}"
                                Command="{Binding DataContext.ToggleEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                Margin="0,0,0,10" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Margin="0,0,6,0"
                                        Text="{Binding IsEnabled, Converter={StaticResource BoolToEnabled}}"
                                        Visibility="Collapsed" />
                                    <TextBlock Text="⏸ Disable at Startup"
                                        Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Text="▶ Enable at Startup"
                                        Visibility="{Binding IsEnabled, Converter={StaticResource InvBoolToVis}}" />
                                </StackPanel>
                            </Button>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource ActionBtn}"
                                    Command="{Binding DataContext.OpenLocationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📂" Margin="0,0,5,0" />
                                        <TextBlock Text="Open Location" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ActionBtn}"
                                    Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋" Margin="0,0,5,0" />
                                        <TextBlock Text="Copy Path" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </Border>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="4" Background="#060911" Padding="24,8"
            BorderThickness="0,1,0,0" BorderBrush="#0F1629">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#334155"
                    VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                    Text="StartupSpy v1.0  —  Run as Administrator for full access"
                    FontSize="10" Foreground="#1E2535" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>